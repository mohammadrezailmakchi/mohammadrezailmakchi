---
// src/components/GlobalFooter.astro
interface Props {
  lang?: 'en' | 'fa';
}

const { lang = 'en' } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-8 border-t border-zinc-200/50 dark:border-slate-900/50 transition-theme bg-zinc-50 dark:bg-slate-950">
  <div class="max-w-7xl mx-auto px-8 sm:px-12 md:px-16 flex flex-col sm:flex-row items-center justify-between gap-4 text-[10px] sm:text-xs font-semibold tracking-wider uppercase text-zinc-400 dark:text-slate-500">
    <div class="select-none text-center sm:text-start">
      {lang === 'fa' ? (
        <span>© {currentYear} MOHAMMADREZA ILMAKCHI. تمامی حقوق محفوظ است.</span>
      ) : (
        <span>© {currentYear} MOHAMMADREZA ILMAKCHI. All rights reserved.</span>
      )}
    </div>
    
    <div class="flex items-center gap-4">
      <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 dark:bg-indigo-600 animate-pulse"></span>
      <span class="text-[9px] sm:text-[10px] tracking-widest">{lang === 'fa' ? 'مهندسی و توسعه محصول' : 'Designed & Engineered'}</span>
    </div>
  </div>
</footer>
