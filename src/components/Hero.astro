---
import { getTranslations } from '../utils/i18n';
import { withBase } from '../utils/baseUrl';

interface Props {
  lang?: 'en' | 'fa';
}

const { lang = 'en' } = Astro.props;
const t = getTranslations(lang);
---
<!-- Hero Section -->
<section class="relative z-10 w-full flex flex-col items-center justify-center px-6 sm:px-12 md:px-16 pt-24 pb-20 md:pt-28 md:pb-28 lg:pt-32 lg:pb-36">
  <div class="w-full max-w-7xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 w-full items-start">
      
      <!-- Left Column: Asymmetrical Title -->
      <div class="lg:col-span-8 space-y-6">
        <!-- Subheading Tag -->
        <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full border border-zinc-200 dark:border-slate-900 bg-zinc-150/40 dark:bg-slate-900/10 text-zinc-650 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest select-none">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-650 dark:bg-indigo-400"></span>
          {t.hero.tag}
        </div>
        
        <h1 class="text-[2rem] min-[360px]:text-[2.5rem] sm:text-6xl md:text-[5.5rem] lg:text-[6.5rem] xl:text-[7.5rem] font-black tracking-tighter text-zinc-900 dark:text-white leading-[0.92] font-display uppercase animate-fade-in-up">
          {t.hero.headline_part1}<br/>
          {t.hero.headline_part2}<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 via-indigo-500 to-purple-600 dark:from-indigo-400 dark:via-indigo-355 dark:to-purple-400">{t.hero.headline_ship}</span>
        </h1>
      </div>
      
      <!-- Right Column: Asymmetrical Subtext & Soft Tech Stack -->
      <div class="lg:col-span-4 lg:pt-16 space-y-8 animate-fade-in-up-delay">
        <p class="text-zinc-550 dark:text-slate-400 text-sm sm:text-base leading-relaxed font-light">
          {t.hero.paragraph}
        </p>

        <!-- Call to Action Buttons -->
        <div class="flex flex-wrap gap-4 pt-2">
          <a
            href={withBase(lang === 'fa' ? '/fa/projects' : '/projects')}
            class="px-7 py-3.5 bg-indigo-650 text-white hover:bg-indigo-750 dark:bg-indigo-500 dark:text-white dark:hover:bg-indigo-400 font-bold text-xs uppercase tracking-widest rounded-full hover:scale-105 active:scale-95 transition-all duration-300 shadow-md shadow-indigo-600/10 dark:shadow-none cursor-pointer"
          >
            {t.hero.cta_projects}
          </a>
          <a
            href={withBase(lang === 'fa' ? '/fa/about' : '/about')}
            class="px-7 py-3.5 border border-zinc-350 text-zinc-700 hover:bg-zinc-100 hover:text-zinc-900 dark:border-slate-800 dark:text-slate-300 dark:hover:bg-slate-900/40 dark:hover:text-white font-bold text-xs uppercase tracking-widest rounded-full hover:scale-105 active:scale-95 transition-all duration-300 cursor-pointer"
          >
            {t.hero.cta_about}
          </a>
        </div>

        <!-- Soft Tech Stack (clean typography with 2px transitional accent shift) -->
        <div class="flex flex-wrap gap-x-5 gap-y-3 pt-6 border-t border-zinc-200/60 dark:border-slate-900/60 w-full">
          {['Astro', 'React', 'Tailwind', 'TypeScript', 'Node.js', 'FastAPI', 'PostgreSQL', 'Docker'].map((tech) => (
            <span class="group relative text-xs font-semibold text-zinc-500 dark:text-slate-450 hover:text-indigo-650 dark:hover:text-indigo-400 cursor-default transition-all duration-300 transform hover:-translate-y-[2px] select-none py-0.5">
              {tech}
              <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-indigo-650 dark:bg-indigo-400 transition-all duration-300 group-hover:w-full"></span>
            </span>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
