---
// src/components/ThatsNotAll.astro
import { getTranslations } from '../utils/i18n';

interface Props {
  lang?: 'en' | 'fa';
}

const { lang = 'en' } = Astro.props;
const t = getTranslations(lang);
---
<div id="liquid-content" class="relative z-20 w-full max-w-7xl px-8 sm:px-12 md:px-16 flex flex-col items-center justify-center text-center opacity-0 pointer-events-none">
  
  <!-- Headline / Microcopy -->
  <div class="space-y-6 max-w-3xl mx-auto">
    <div id="liquid-tag" class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full border border-zinc-200 bg-zinc-100 text-indigo-650 dark:border-slate-800 dark:bg-slate-900/40 dark:text-indigo-400 text-[10px] font-bold uppercase tracking-widest select-none">
      <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 dark:bg-indigo-600 animate-pulse"></span>
      {t.thatsNotAll.tag}
    </div>
    
    <h2 id="liquid-title" class="text-5xl sm:text-7xl md:text-8xl font-black tracking-tighter text-zinc-900 dark:text-white leading-none font-display uppercase">
      {lang === 'fa' ? t.thatsNotAll.title : <Fragment>That's<br/>not all.</Fragment>}
    </h2>
    
    <p id="liquid-subtitle" class="text-zinc-550 dark:text-slate-405 text-sm sm:text-base md:text-lg max-w-xl mx-auto leading-relaxed font-light">
      {t.thatsNotAll.subtitle}
    </p>
  </div>

  <!-- Inverted CTA Cards Grid (Dynamic contrast overlay) -->
  <div id="liquid-grid" class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-6 w-full mt-6 sm:mt-16 max-w-5xl mx-auto">
    
    <!-- Card 1: Projects Showcase -->
    <a href={lang === 'fa' ? '/fa/projects' : '/projects'} class="group backdrop-acrylic p-4 md:p-6 rounded-2xl md:rounded-3xl border border-zinc-200 dark:border-slate-800/80 hover:border-indigo-500/40 dark:hover:border-indigo-400/40 transition-all duration-300 flex flex-col justify-between h-36 sm:h-44 md:h-56 text-start">
      <div class="space-y-1 sm:space-y-3">
        <span class="text-[8px] sm:text-[9px] font-bold uppercase tracking-wider text-indigo-650 dark:text-indigo-450">{t.thatsNotAll.card1_tag}</span>
        <h3 class="text-sm sm:text-base md:text-lg font-bold text-zinc-900 dark:text-white uppercase tracking-tight">{t.thatsNotAll.card1_title}</h3>
        <p class="text-[9px] sm:text-[10px] md:text-[11px] text-zinc-550 dark:text-slate-400 leading-normal font-light line-clamp-2 md:line-clamp-none">{t.thatsNotAll.card1_desc}</p>
      </div>
      <span class="text-[8px] sm:text-[9px] uppercase tracking-widest text-indigo-650 dark:text-indigo-455 font-bold group-hover:text-zinc-900 dark:group-hover:text-white transition-colors">{t.thatsNotAll.card1_cta}</span>
    </a>

    <!-- Card 2: About Biography -->
    <a href={lang === 'fa' ? '/fa/about' : '/about'} class="group backdrop-acrylic p-4 md:p-6 rounded-2xl md:rounded-3xl border border-zinc-200 dark:border-slate-800/80 hover:border-purple-500/40 dark:hover:border-purple-400/40 transition-all duration-300 flex flex-col justify-between h-36 sm:h-44 md:h-56 text-start">
      <div class="space-y-1 sm:space-y-3">
        <span class="text-[8px] sm:text-[9px] font-bold uppercase tracking-wider text-purple-650 dark:text-purple-450">{t.thatsNotAll.card2_tag}</span>
        <h3 class="text-sm sm:text-base md:text-lg font-bold text-zinc-900 dark:text-white uppercase tracking-tight">{t.thatsNotAll.card2_title}</h3>
        <p class="text-[9px] sm:text-[10px] md:text-[11px] text-zinc-550 dark:text-slate-400 leading-normal font-light line-clamp-2 md:line-clamp-none">{t.thatsNotAll.card2_desc}</p>
      </div>
      <span class="text-[8px] sm:text-[9px] uppercase tracking-widest text-purple-650 dark:text-purple-455 font-bold group-hover:text-zinc-900 dark:group-hover:text-white transition-colors">{t.thatsNotAll.card2_cta}</span>
    </a>

    <!-- Card 3: Experience Timeline -->
    <div class="group backdrop-acrylic p-4 md:p-6 rounded-2xl md:rounded-3xl border border-zinc-200 dark:border-slate-800/80 hover:border-emerald-500/40 dark:hover:border-emerald-400/40 transition-all duration-300 flex flex-col justify-between h-36 sm:h-44 md:h-56 text-start">
      <div class="space-y-1 sm:space-y-3">
        <span class="text-[8px] sm:text-[9px] font-bold uppercase tracking-wider text-emerald-650 dark:text-emerald-455">{t.thatsNotAll.card3_tag}</span>
        <h3 class="text-sm sm:text-base md:text-lg font-bold text-zinc-900 dark:text-white uppercase tracking-tight">{t.thatsNotAll.card3_title}</h3>
        <p class="text-[9px] sm:text-[10px] md:text-[11px] text-zinc-550 dark:text-slate-400 leading-normal font-light line-clamp-2 md:line-clamp-none">{t.thatsNotAll.card3_desc}</p>
      </div>
      <span class="text-[8px] sm:text-[9px] uppercase tracking-widest text-zinc-450 dark:text-slate-500 font-bold">{t.thatsNotAll.card3_cta}</span>
    </div>

    <!-- Card 4: Academics Spec -->
    <div class="group backdrop-acrylic p-4 md:p-6 rounded-2xl md:rounded-3xl border border-zinc-200 dark:border-slate-800/80 hover:border-cyan-500/40 dark:hover:border-cyan-400/40 transition-all duration-300 flex flex-col justify-between h-36 sm:h-44 md:h-56 text-start">
      <div class="space-y-1 sm:space-y-3">
        <span class="text-[8px] sm:text-[9px] font-bold uppercase tracking-wider text-cyan-650 dark:text-cyan-455">{t.thatsNotAll.card4_tag}</span>
        <h3 class="text-sm sm:text-base md:text-lg font-bold text-zinc-900 dark:text-white uppercase tracking-tight">{t.thatsNotAll.card4_title}</h3>
        <p class="text-[9px] sm:text-[10px] md:text-[11px] text-zinc-550 dark:text-slate-400 leading-normal font-light line-clamp-2 md:line-clamp-none">{t.thatsNotAll.card4_desc}</p>
      </div>
      <span class="text-[8px] sm:text-[9px] uppercase tracking-widest text-zinc-450 dark:text-slate-500 font-bold">{t.thatsNotAll.card4_cta}</span>
    </div>

  </div>

</div>
