---
// src/components/Navbar.astro
import ThemeToggle from './ThemeToggle.astro';
import { getTranslations } from '../utils/i18n';
import { withBase } from '../utils/baseUrl';

interface Props {
  activePath?: string;
  lang?: 'en' | 'fa';
}

const { activePath = '/', lang = 'en' } = Astro.props;
const t = getTranslations(lang);

const navItems = [
  { label: t.nav.home, path: lang === 'fa' ? '/fa' : '/' },
  { label: t.nav.projects, path: lang === 'fa' ? '/fa/projects' : '/projects' },
  { label: t.nav.about, path: lang === 'fa' ? '/fa/about' : '/about' },
  { label: t.nav.contact, path: lang === 'fa' ? '/fa/contact' : '/contact' }
];

// Determine target path for language toggle
const getTargetLanguagePath = () => {
  if (lang === 'en') {
    // English -> Persian
    if (activePath === '/') return '/fa';
    if (activePath.startsWith('/fa')) return activePath;
    return `/fa${activePath}`;
  } else {
    // Persian -> English
    if (activePath === '/fa') return '/';
    return activePath.replace(/^\/fa/, '') || '/';
  }
};

const targetLangPath = getTargetLanguagePath();
const toggleLabel = lang === 'en' ? 'FA' : 'EN';
const toggleTooltip = lang === 'en' ? 'فارسی' : 'English';
---

<header class="sticky top-0 z-50 w-full backdrop-acrylic border-b border-zinc-200/50 dark:border-slate-900/50 transition-theme">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 h-16 flex items-center justify-between">
    <!-- Brand / Monogram -->
    <a href={withBase(lang === 'fa' ? '/fa' : '/')} class="flex items-center gap-2.5 group">
      <span class="w-2.5 h-2.5 rounded-full bg-indigo-650 dark:bg-indigo-400 group-hover:scale-110 transition-transform duration-300"></span>
      <span class="font-display font-light text-sm sm:text-base tracking-widest text-zinc-900 dark:text-white transition-colors duration-300 group-hover:text-indigo-650 dark:group-hover:text-indigo-400">
        ILMAKCHI
      </span>
    </a>

    <!-- Desktop Navigation & Theme Toggle -->
    <div class="hidden md:flex items-center gap-6">
      <nav class="flex gap-1.5">
        {navItems.map((item) => (
          <a
            href={withBase(item.path)}
            class={`px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest transition-all duration-300 border ${
              activePath === item.path
                ? 'bg-indigo-50/80 text-indigo-650 border-indigo-100/40 dark:bg-indigo-500/10 dark:text-indigo-300 dark:border-indigo-500/20 shadow-sm'
                : 'text-zinc-650 hover:text-zinc-950 hover:bg-zinc-150/40 dark:text-slate-400 dark:hover:text-white dark:hover:bg-slate-900/40 border-transparent'
            }`}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <span class="w-px h-5 bg-zinc-200 dark:bg-slate-800"></span>
      <!-- Language Selector Toggle -->
      <a
        href={withBase(targetLangPath)}
        class="lang-toggle-btn group px-3.5 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest border border-zinc-200 hover:border-zinc-900 bg-zinc-50 hover:bg-zinc-900 text-zinc-700 hover:text-white dark:border-slate-800/80 dark:hover:border-white dark:bg-slate-900/40 dark:hover:bg-white dark:text-slate-350 dark:hover:text-slate-950 transition-all duration-300 flex items-center justify-center gap-1.5 cursor-pointer select-none"
        title={toggleTooltip}
      >
        <svg class="w-3 h-3 text-zinc-400 group-hover:text-white dark:text-slate-500 dark:group-hover:text-slate-950 transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </svg>
        <span>
          {toggleLabel}
        </span>
      </a>

      <span class="w-px h-5 bg-zinc-200 dark:bg-slate-800"></span>

      <ThemeToggle />
    </div>

    <!-- Mobile Header Controls (visible on screens < 768px) -->
    <div class="flex md:hidden items-center gap-4">
      <!-- Language Selector Toggle (Mobile) -->
      <a
        href={withBase(targetLangPath)}
        class="lang-toggle-btn group px-3 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest border border-zinc-200 hover:border-zinc-900 bg-zinc-50 hover:bg-zinc-900 text-zinc-700 hover:text-white dark:border-slate-800/80 dark:hover:border-white dark:bg-slate-900/40 dark:hover:bg-white dark:text-slate-350 dark:hover:text-slate-950 transition-all duration-300 flex items-center justify-center gap-1.5 cursor-pointer select-none"
        title={toggleTooltip}
      >
        <svg class="w-3 h-3 text-zinc-400 group-hover:text-white dark:text-slate-500 dark:group-hover:text-slate-950 transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </svg>
        <span>
          {toggleLabel}
        </span>
      </a>

      <span class="w-px h-5 bg-zinc-200 dark:bg-slate-800"></span>

      <ThemeToggle />
      
      <span class="w-px h-5 bg-zinc-200 dark:bg-slate-800"></span>

      <!-- Hamburger Button (Tap Target) -->
      <button
        id="mobile-menu-btn"
        class="relative w-10 h-10 flex flex-col justify-center items-center gap-1.5 focus:outline-none cursor-pointer text-zinc-650 dark:text-slate-400 hover:text-zinc-900 dark:hover:text-white active:scale-95 transition-transform duration-200 select-none z-50 touch-manipulation"
        aria-label="Toggle Menu"
        style="touch-action: manipulation;"
      >
        <span class="w-5 h-[2px] bg-current transform transition-all duration-300 origin-center" id="hamburger-line-1"></span>
        <span class="w-5 h-[2px] bg-current transform transition-all duration-300 origin-center" id="hamburger-line-2"></span>
        <span class="w-5 h-[2px] bg-current transform transition-all duration-300 origin-center" id="hamburger-line-3"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Full-screen Navigation Overlay -->
