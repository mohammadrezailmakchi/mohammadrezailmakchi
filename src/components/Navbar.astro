  class="fixed inset-0 z-45 bg-zinc-50/98 dark:bg-slate-950/98 backdrop-blur-xl flex flex-col justify-between items-center py-20 transition-all duration-300 ease-out opacity-0 translate-y-[-100%] pointer-events-none select-none"
