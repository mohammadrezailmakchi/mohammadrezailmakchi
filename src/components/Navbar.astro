<script>
  function setupMobileMenu() {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menuOverlay = document.getElementById('mobile-menu-overlay');
    const line1 = document.getElementById('hamburger-line-1');
    const line2 = document.getElementById('hamburger-line-2');
    const line3 = document.getElementById('hamburger-line-3');
    const links = document.querySelectorAll('.mobile-nav-link');
    const fadeElements = document.querySelectorAll('.mobile-nav-fade-in');

    if (!menuBtn || !menuOverlay) return;

    let isOpen = false;

    function toggleMenu(e?: Event) {
      if (e) {
        e.preventDefault();
        e.stopPropagation();
      }
      isOpen = !isOpen;

      if (isOpen) {
        // Open state
        menuOverlay.classList.remove('opacity-0', 'translate-y-[-100%]', 'pointer-events-none');
        menuOverlay.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');

        // Hamburger animation to X
        if (line1) line1.style.transform = 'translateY(8px) rotate(45deg)';
        if (line2) line2.style.opacity = '0';
        if (line3) line3.style.transform = 'translateY(-8px) rotate(-45deg)';

        // Fade in links
        links.forEach((link) => {
          link.classList.remove('opacity-0', 'translate-y-4');
          link.classList.add('opacity-100', 'translate-y-0');
        });

        // Fade in control deck items
        fadeElements.forEach((el) => {
          el.classList.remove('opacity-0', 'translate-y-4');
          el.classList.add('opacity-100', 'translate-y-0');
        });

        // Prevent body scroll when menu is open
        document.body.style.overflow = 'hidden';
      } else {
        // Close state
        menuOverlay.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        menuOverlay.classList.add('opacity-0', 'translate-y-[-100%]', 'pointer-events-none');

        // Hamburger restoration
        if (line1) line1.style.transform = 'none';
        if (line2) line2.style.opacity = '1';
        if (line3) line3.style.transform = 'none';

        // Reset link animation states
        links.forEach((link) => {
          link.classList.remove('opacity-100', 'translate-y-0');
          link.classList.add('opacity-0', 'translate-y-4');
        });

        // Reset content deck animation states
        fadeElements.forEach((el) => {
          el.classList.remove('opacity-100', 'translate-y-0');
          el.classList.add('opacity-0', 'translate-y-4');
        });

        // Restore body scroll
        document.body.style.overflow = '';
      }
    }

    // Toggle menu on click/tap
    menuBtn.addEventListener('click', toggleMenu);
    
    // Close overlay if a link is clicked
    links.forEach((link) => {
      link.addEventListener('click', () => {
        if (isOpen) toggleMenu();
      });
    });

    // Handle viewport changes to auto-close if width goes past mobile breakpoint
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768 && isOpen) {
        toggleMenu();
      }
    });
  }

  function setupLangToggle() {
    const btns = document.querySelectorAll('.lang-toggle-btn');
    btns.forEach(btn => {
      if (btn.getAttribute('data-lang-initialized')) return;
      btn.setAttribute('data-lang-initialized', 'true');

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const targetPath = btn.getAttribute('href');
        if (!targetPath) return;

        // Set session storage flag to tell target page to render at opacity: 0 and blurred initially
        if (typeof sessionStorage !== 'undefined') {
          sessionStorage.setItem('lang-switch-active', 'true');
        }

        // Select main container to fade/blur out
        const mainContent = document.querySelector('main') || document.body;

        // Import GSAP dynamically to trigger fade-out transition
        import('gsap').then(({ gsap }) => {
          // Force hardware acceleration layer promotion
          if (mainContent instanceof HTMLElement) {
            mainContent.style.willChange = 'filter, opacity';
          }
          
          gsap.to(mainContent, {
            opacity: 0,
            filter: 'blur(8px)',
            duration: 0.200, // 200ms
            ease: 'power2.out',
            onComplete: () => {
              window.location.href = targetPath;
            }
          });
        });
      });
    });
  }

  // Bind on normal load & after swap
  document.addEventListener('DOMContentLoaded', () => {
    setupMobileMenu();
    setupLangToggle();
  });
  document.addEventListener('astro:after-swap', () => {
    setupMobileMenu();
    setupLangToggle();
  });
</script>
