---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import { getTranslations } from '../utils/i18n';

const lang = 'en';
const t = getTranslations(lang);
---

<Layout title="Contact & Partnership | Full-Stack Founder" activePath="/contact" lang={lang} description="Reach out directly or submit your project parameters, bounds, and urgency through our secure intake form.">
  <main class="relative z-10 w-full min-h-screen flex flex-col items-center px-6 sm:px-12 md:px-16 pt-24 md:pt-28 pb-24">
    <div class="w-full max-w-7xl">
      
      <!-- Asymmetrical Split Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        
        <!-- Left Column: Direct Access Details -->
        <div class="lg:col-span-5 space-y-10 animate-fade-in lg:sticky lg:top-24">
          <div class="space-y-6">
            <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full border border-zinc-200 dark:border-slate-900 bg-zinc-150/40 dark:bg-slate-900/10 text-zinc-650 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest select-none">
              <span class="w-1.5 h-1.5 rounded-full bg-indigo-650 dark:bg-indigo-400"></span>
              {t.contact.tag}
            </div>
            
            <h1 class="text-4xl sm:text-5xl md:text-6xl font-black tracking-tight text-zinc-900 dark:text-white leading-[1.05] font-display uppercase">
              {lang === 'fa' ? t.contact.title : <Fragment>Get In<br/>Touch.</Fragment>}
            </h1>
            
            <p class="text-zinc-550 dark:text-slate-400 text-sm sm:text-base leading-relaxed font-light max-w-md">
              {t.contact.subtitle}
            </p>
          </div>

          <!-- Direct Channels -->
          <div class="space-y-8 pt-8 border-t border-zinc-200/60 dark:border-slate-900/60">
            <!-- Email -->
            <div class="space-y-2">
              <span class="text-[10px] font-bold text-zinc-455 dark:text-slate-500 uppercase tracking-widest block">{t.contact.email_label}</span>
              <a 
                href="mailto:mohammadrezailmakchi@gmail.com" 
                class="group text-lg sm:text-xl font-light text-zinc-900 dark:text-white hover:text-indigo-655 dark:hover:text-indigo-400 transition-colors duration-300 font-display flex items-center gap-2"
              >
                mohammadrezailmakchi@gmail.com
                <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>

            <!-- Phone -->
            <div class="space-y-2">
              <span class="text-[10px] font-bold text-zinc-455 dark:text-slate-500 uppercase tracking-widest block">{t.contact.phone_label}</span>
              <div class="flex flex-wrap items-center gap-4">
                <a 
                  href="tel:+989926771399" 
                  class="group text-lg sm:text-xl font-light text-zinc-900 dark:text-white hover:text-indigo-655 dark:hover:text-indigo-400 transition-colors duration-300 font-display flex items-center gap-2"
                >
                  +98 992 677 1399
                  <span class="text-xs text-zinc-400 dark:text-slate-655 font-sans font-normal">{t.contact.phone_sub}</span>
                </a>
                
                <!-- Chat Actions -->
                <div class="flex items-center gap-3">
                  <!-- WhatsApp -->
                  <a
                    href="https://wa.me/989926771399"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="p-2 rounded-xl bg-zinc-100 hover:bg-zinc-200 dark:bg-slate-900/50 dark:hover:bg-slate-800 text-zinc-650 hover:text-green-600 dark:text-slate-400 dark:hover:text-green-400 border border-zinc-200/50 dark:border-slate-900/50 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-green-500/50"
                    aria-label="Contact on WhatsApp"
                  >
                    <svg class="w-4.5 h-4.5 fill-current" viewBox="0 0 24 24">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                    </svg>
                  </a>
                  <!-- Telegram -->
                  <a
                    href="https://t.me/+989926771399"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="p-2 rounded-xl bg-zinc-100 hover:bg-zinc-200 dark:bg-slate-900/50 dark:hover:bg-slate-800 text-zinc-650 hover:text-sky-500 dark:text-slate-400 dark:hover:text-sky-400 border border-zinc-200/50 dark:border-slate-900/50 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-sky-500/50"
                    aria-label="Contact on Telegram"
                  >
                    <svg class="w-4.5 h-4.5 fill-current" viewBox="0 0 24 24">
                      <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.703.064-1.237-.465-1.917-.911-1.066-.7-1.67-1.132-2.705-1.815-1.196-.789-.42-1.223.262-1.93.177-.185 3.262-2.992 3.322-3.247.007-.032.014-.15-.056-.212-.07-.062-.173-.04-.247-.023-.105.024-1.782 1.132-5.05 3.339-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.75-.244-1.347-.373-1.295-.788.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635.099-.002.321.023.465.14.12.097.153.228.163.325.01.096.012.217-.005.326z" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>

            <!-- Socials -->
            <div class="space-y-3">
              <span class="text-[10px] font-bold text-zinc-455 dark:text-slate-500 uppercase tracking-widest block">{t.contact.networks_label}</span>
              <div class="flex flex-wrap gap-x-5 gap-y-2.5">
                {[
                  { name: 'GitHub', url: 'https://github.com/mohammadrezailmakchi' },
                  { name: 'LinkedIn', url: 'https://www.linkedin.com/in/mohammadreza-ilmakchi-242242267/' },
                  { name: 'Instagram', url: 'https://www.instagram.com/life_of_mohammadrez/' }
                ].map((network) => (
                  <a 
                    href={network.url} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="group relative text-xs font-semibold text-zinc-500 dark:text-slate-455 hover:text-indigo-655 dark:hover:text-indigo-400 transition-all duration-300 transform hover:-translate-y-[2px] py-0.5 select-none"
                  >
                    {network.name}
                    <span class="absolute bottom-0 left-0 w-0 h-[1.5px] bg-indigo-650 dark:bg-indigo-400 transition-all duration-300 group-hover:w-full"></span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: The Contact Form -->
        <div class="lg:col-span-7">
          <Contact lang={lang} />
        </div>

      </div>

    </div>
  </main>
</Layout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
